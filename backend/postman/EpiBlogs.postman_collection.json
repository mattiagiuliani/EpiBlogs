    {
      "name": "Posts",
      "description": "Le letture sono pubbliche. I post possono essere creati, modificati e cancellati solo dal proprietario del profilo autore associato (sessione cookie).",
      "item": [
        {
          "name": "Get Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts?search=&category=&tag=&tags=&page=&limit=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "posts"
              ],
              "query": [
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "category",
                  "value": ""
                },
                {
                  "key": "tag",
                  "value": ""
                },
                {
                  "key": "tags",
                  "value": ""
                },
                {
                  "key": "page",
                  "value": ""
                },
                {
                  "key": "limit",
                  "value": ""
                }
              ]
            },
            "description": "Lista pubblica dei post. Supporta filtro title regex via `search`, filtro categoria via slug in `category`, e filtro tag via `tag` oppure `tags` (comma-separated). Paginazione con `page` e `limit`."
          }
        },
        {
          "name": "Get Post Tags",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts/tags?limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "tags"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            },
            "description": "Ritorna i tag disponibili aggregati dal database nel formato `{ data: [{ tag, count }] }`, ordinati per frequenza desc e poi alfabeticamente. `limit` opzionale (default 50, max 100)."
          }
        },
        {
          "name": "Search Posts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"search\": \"express mongodb\",\n  \"categorySlug\": \"web-development\",\n  \"tags\": [\"web-dev\", \"javascript\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts/search?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "search"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Ricerca strutturata tramite text index MongoDB. Il body supporta `search`, `categorySlug` e `tags`; la paginazione resta sui query params `page` e `limit`."
          }
        },
        {
          "name": "Get Post By Id",
          "request": {
