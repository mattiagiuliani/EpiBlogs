{
  "info": {
    "name": "EpiBlogs API",
    "_postman_id": "c2ec0790-88c2-4a50-bd9b-f1a661f4b1cf",
    "description": "Collection Postman allineata al progetto EpiBlogs. Copre register/login JWT, recupero /me, Google OAuth bootstrap ed exchange code, CRUD authors/posts/comments, upload avatar/cover e ownership sui record.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "authorId",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    },
    {
      "key": "commentId",
      "value": ""
    },
    {
      "key": "googleAuthCode",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "I flussi email/password e Google convergono nello stesso JWT applicativo. Le request di register/login salvano automaticamente token e authorId nelle variabili di collection.",
      "item": [
        {
          "name": "Register Author",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set('authorId', data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"secret123\",\n  \"firstName\": \"Mario\",\n  \"lastName\": \"Rossi\",\n  \"profile\": \"Full stack developer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/authors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "authors"
              ]
            },
            "description": "Route pubblica usata anche dal frontend per creare un autore locale."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('accessToken', data.token);",
                  "}",
                  "if (data && data.author && data.author._id) {",
                  "  pm.collectionVariables.set('authorId', data.author._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me"
              ]
            }
          }
        },
        {
          "name": "Start Google OAuth",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "google"
              ]
            },
            "description": "Avvia il redirect OAuth verso Google. Da browser completa il login, poi copia il code restituito alla route frontend /auth/callback se vuoi testare manualmente l'exchange in Postman."
          }
        },
        {
          "name": "Exchange Google Auth Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('accessToken', data.token);",
                  "}",
                  "if (data && data.author && data.author._id) {",
                  "  pm.collectionVariables.set('authorId', data.author._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{googleAuthCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/google/exchange-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "google",
                "exchange-code"
              ]
            },
            "description": "Scambia il one-time code OAuth con il JWT applicativo. Valido solo una volta e a breve scadenza."
          }
        }
      ]
    },
