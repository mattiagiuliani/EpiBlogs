{
  "info": {
    "name": "EpiBlogs API",
    "_postman_id": "c2ec0790-88c2-4a50-bd9b-f1a661f4b1cf",
    "description": "Collection Postman allineata al progetto EpiBlogs (API versionata /api/v1). Copre autenticazione con cookie HttpOnly, Google OAuth exchange, CRUD authors/posts/comments, likes, ownership sui record e upload avatar/cover. Le GET pubbliche non richiedono autenticazione; tutte le mutazioni e /api/v1/auth/me richiedono sessione valida via cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "authorId",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    },
    {
      "key": "commentId",
      "value": ""
    },
    {
      "key": "googleAuthCode",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Flussi auth allineati a /api/v1/auth/*: login, logout, /me e Google exchange usano la sessione via cookie HttpOnly. Register crea soltanto l'autore e non apre automaticamente la sessione. In Postman usa la cookie jar.",
      "item": [
        {
          "name": "Register Author",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set('authorId', data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"secret123\",\n  \"firstName\": \"Mario\",\n  \"lastName\": \"Rossi\",\n  \"profile\": \"Full stack developer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Route pubblica per registrazione autore locale. Crea l'account ma non imposta il cookie di sessione: esegui poi Login per autenticarti in Postman."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.author && data.author._id) {",
                  "  pm.collectionVariables.set('authorId', data.author._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Start Google OAuth",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google"
              ]
            },
            "description": "Avvia il redirect OAuth verso Google. Da browser completa il login, poi copia il code restituito alla route frontend /auth/callback se vuoi testare manualmente l'exchange in Postman."
          }
        },
        {
          "name": "Exchange Google Auth Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.author && data.author._id) {",
                  "  pm.collectionVariables.set('authorId', data.author._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{googleAuthCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google/exchange-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google",
                "exchange-code"
              ]
            },
            "description": "Scambia il one-time code OAuth con il JWT applicativo. Valido solo una volta e a breve scadenza."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Termina la sessione corrente e pulisce la cookie auth."
          }
        }
      ]
    },
