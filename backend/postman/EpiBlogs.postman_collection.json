            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"web-development\",\n  \"title\": \"Titolo articolo\",\n  \"cover\": \"https://example.com/cover.jpg\",\n  \"readTime\": {\n    \"value\": 5,\n    \"unit\": \"min\"\n  },\n  \"author\": \"{{authorId}}\",\n  \"content\": \"<h1>Articolo</h1><p>Contenuto HTML</p>\",\n  \"tags\": [\"web-dev\", \"javascript\", \"api\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts",
