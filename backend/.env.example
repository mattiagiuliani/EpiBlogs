NODE_ENV=development
PORT=3000
MONGODB_CONNECTION_URI=mongodb+srv://username:password@cluster.mongodb.net/epiblogs
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Frontend / CORS
DEVELOPMENT_FRONTEND_URL=http://localhost:5173
DEPLOYMENT_FRONTEND_URL=https://your-vercel-service.onvercel.app
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
# Set to true to allow any *.vercel.app origin (Vercel branch/preview deployments).
# Leave false (or unset) in production unless you need preview deploy access.
CORS_ALLOW_VERCEL_PREVIEWS=false
TRUST_PROXY=

# Auth cookies
# AUTH_COOKIE_SECURE defaults to true in production and false otherwise.
# Use AUTH_COOKIE_SAME_SITE=none only together with AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEVELOPMENT_GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
DEPLOYMENT_GOOGLE_CALLBACK_URL=https://your-render-service.onrender.com/api/v1/auth/google/callback

# OAuth state cookie overrides (optional)
OAUTH_COOKIE_DOMAIN=
OAUTH_COOKIE_SAME_SITE=

# Mail delivery (optional: SMTP or SendGrid)
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
SENDGRID_API_KEY=

# Cloudinary uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Observability
LOG_LEVEL=info

# Deprecated — remove these from your environment if still set:
# JWT_SECRET=           → use JWT_SECRET_KEY instead
# GOOGLE_CALLBACK_URL=  → no longer read; remove from Render/production dashboard
# BACKEND_HOST=         → no longer read; remove from Render/production dashboard
# OAUTH_COOKIE_SECURE=  → use AUTH_COOKIE_SECURE instead
