PORT=3000
MONGODB_CONNECTION_URI=connection_string

FRONTEND_URL=http://localhost:5173
BACKEND_HOST=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_USER=
MAIL_PORT=587
MAIL_HOST=smtp.ethereal.email
MAIL_PASSWORD=
MAIL_FROM=

SENDGRID_API_KEY=

JWT_SECRET_KEY=
# JWT_SECRET is accepted as an alias for JWT_SECRET_KEY (both work)
# JWT_SECRET=

# Logging level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# HttpOnly auth cookie settings
# AUTH_COOKIE_SECURE defaults to true in production, false otherwise
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE: lax | strict | none  (use 'none' + secure=true for cross-site deployments)
# AUTH_COOKIE_SAME_SITE=lax

# CORS — credentials are required for cookie-based auth
# Set to false only if you are using Authorization header exclusively
CORS_ALLOW_CREDENTIALS=true

GOOGLE_CLIENT_ID=__INSERT_CLIENT_ID_HERE__
GOOGLE_CLIENT_SECRET=__INSERT_CLIENT_SECRET_HERE__

# Google OAuth callback URLs — the server selects automatically based on NODE_ENV:
#   NODE_ENV=production  → DEPLOYMENT_GOOGLE_CALLBACK_URL
#   NODE_ENV=development → DEVELOPMENT_GOOGLE_CALLBACK_URL
# GOOGLE_CALLBACK_URL is the legacy fallback (used when the split vars are absent).
DEVELOPMENT_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
DEPLOYMENT_GOOGLE_CALLBACK_URL=https://epiblogs-mxl1.onrender.com/auth/google/callback
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
