NODE_ENV=development
PORT=3000
MONGODB_CONNECTION_URI=mongodb+srv://username:password@cluster.mongodb.net/epiblogs
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY=

# Auth cookies
# AUTH_COOKIE_SECURE defaults to true in production and false otherwise.
# Use AUTH_COOKIE_SAME_SITE=none only together with AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEVELOPMENT_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
DEPLOYMENT_GOOGLE_CALLBACK_URL=https://your-render-service.onrender.com/auth/google/callback

# OAuth state cookie overrides (optional)
OAUTH_COOKIE_DOMAIN=
OAUTH_COOKIE_SAME_SITE=

# Mail delivery (optional: SMTP or SendGrid)
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
SENDGRID_API_KEY=

# Cloudinary uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Observability
LOG_LEVEL=info

# Deprecated aliases kept for backward compatibility only:
# JWT_SECRET=
# GOOGLE_CALLBACK_URL=
# OAUTH_COOKIE_SECURE=
