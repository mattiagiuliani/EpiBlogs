# EpiBlogs frontend environment variables
# ─────────────────────────────────────────
# SETUP INSTRUCTIONS
#
# LOCAL DEVELOPMENT
#   cp frontend/.env.example frontend/.env
#   Then restart Vite. The app will connect to your local backend.
#
# VERCEL (production / preview)
#   Set VITE_API_URL in the Vercel dashboard:
#   Project → Settings → Environment Variables
#   Set it for: Production, Preview, and Development.
#   Value: https://epiblogs-mxl1.onrender.com
#   Then trigger a new deploy for the change to take effect.
#
# NOTE: frontend/.env is gitignored. Never commit real values.
# ─────────────────────────────────────────

# Backend API base URL.
# Local dev  → local Express server
# Production → Render deployment
VITE_API_URL=http://localhost:3000
