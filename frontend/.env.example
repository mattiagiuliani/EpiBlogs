# Copy this file to .env for local development.
# In production (Vercel), set these as environment variables in the Vercel dashboard.

# Backend API base URL.
# Local dev → points to the local Express server (default fallback if unset).
# Vercel production → must be set to https://epiblogs-mxl1.onrender.com
VITE_API_URL=http://localhost:3000
