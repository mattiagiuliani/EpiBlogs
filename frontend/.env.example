# Copy this file to .env for local development.
# In production (Vercel), set these as environment variables in the Vercel dashboard.

# Backend API base URL.
# Local dev: points to the local Express server.
# Vercel production: set to https://epiblogs-mxl1.onrender.com
VITE_API_BASE_URL=http://localhost:3000

# Optional. Defaults to window.location.origin in the browser.
# Needed only if the frontend is served from a path prefix or non-standard port.
# VITE_FRONTEND_BASE_URL=http://localhost:5173
