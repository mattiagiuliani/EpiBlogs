{
  "name": "epiblogs-root",
  "private": true,
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "npm --prefix backend run start",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "lint": "npm run lint:frontend",
    "lint:frontend": "npm --prefix frontend run lint",
    "check": "npm run check:backend",
    "check:backend": "npm --prefix backend run check",
    "test": "vitest run test --pool threads",
    "test:watch": "vitest test --pool threads",
    "test:frontend": "vitest run test/frontend --pool threads",
    "test:backend": "vitest run test/backend --pool threads",
    "verify": "npm run test && npm run check && npm run lint && npm run build"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
